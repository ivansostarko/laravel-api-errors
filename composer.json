{
    "name": "ivansostarko/laravel-api-errors",
    "description": "Centralized, enum-based API error codes for Laravel — frontend-safe, RFC 7807 compatible, Swagger-ready, with TypeScript export, Sentry integration, and request tracing.",
    "keywords": ["laravel", "api", "errors", "error-codes", "rfc7807", "exception", "swagger", "typescript"],
    "license": "MIT",
    "homepage": "https://github.com/ivansostarko/laravel-api-errors",
    "authors": [
        {
            "name": "Ivan Sostarko",
            "homepage": "https://github.com/ivansostarko"
        }
    ],
    "support": {
        "issues": "https://github.com/ivansostarko/laravel-api-errors/issues",
        "source": "https://github.com/ivansostarko/laravel-api-errors"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelApiErrors\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelApiErrors\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelApiErrors\\ApiErrorsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
